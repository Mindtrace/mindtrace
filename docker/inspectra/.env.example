# =========================
# Docker Compose
# =========================
API_PORT=8000

# Inspectra API base URL (host:port the app binds to; use 0.0.0.0 so container accepts connections)
INSPECTRA__URL=http://0.0.0.0:8000

# =========================
# MongoDB (used by mongo + api services)
# =========================
MONGO_INITDB_ROOT_USERNAME=inspectra_root
MONGO_INITDB_ROOT_PASSWORD=inspectra_root_password
MONGO_INITDB_DATABASE=inspectra

# API uses this to connect (authSource=admin for root user)
MONGO_URI=mongodb://inspectra_root:inspectra_root_password@mongo:27017/inspectra?authSource=admin
MONGO_DB_NAME=inspectra

# =========================
# Inspectra API (JWT / Auth)
# =========================
# Change JWT_SECRET in production
JWT_SECRET=change_me_super_secret
JWT_ALGORITHM=HS256
# Access token TTL in seconds (recommended: 900 = 15 min)
JWT_EXPIRES_IN=900
# Refresh token TTL in seconds (recommended: 604800 = 7 days)
REFRESH_TOKEN_EXPIRES_IN=604800

# Optional: CORS origins (comma-separated). Default: http://localhost:3000
# CORS_ALLOW_ORIGINS=http://localhost:3000

# =========================
# Mongo Express (optional UI)
# =========================
ME_CONFIG_MONGODB_ADMINUSERNAME=inspectra_root
ME_CONFIG_MONGODB_ADMINPASSWORD=inspectra_root_password
ME_CONFIG_MONGODB_SERVER=mongo
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=admin

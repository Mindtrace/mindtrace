# Copy to docker/datalake/.env and adjust if needed.

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

MINDTRACE_DATALAKE__SERVICE_HOST=0.0.0.0
MINDTRACE_DATALAKE__SERVICE_PORT=8080

MINDTRACE_DATALAKE__MONGO_DB_URI=mongodb://mongodb:27017
MINDTRACE_DATALAKE__MONGO_DB_NAME=mindtrace_datalake

MINDTRACE_DATALAKE__MOUNT_NAME=minio
MINDTRACE_DATALAKE__S3_BUCKET=datalake
MINDTRACE_DATALAKE__S3_PREFIX=
MINDTRACE_DATALAKE__S3_ENDPOINT=minio:9000
MINDTRACE_DATALAKE__S3_ACCESS_KEY=minioadmin
MINDTRACE_DATALAKE__S3_SECRET_KEY=minioadmin
MINDTRACE_DATALAKE__S3_SECURE=false

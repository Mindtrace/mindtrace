# Inspectra backend – local dev (no Docker)
# Copy to .env and adjust. Used when running the API or seed script directly.

# Bind address: 0.0.0.0 makes the API reachable at both localhost and your LAN IP (e.g. http://192.168.50.228:8080)
INSPECTRA__URL=http://0.0.0.0:8080
CORS_ALLOW_ORIGINS=http://localhost:3000

# JWT (access token and refresh token TTL in seconds)
JWT_SECRET=change_me_super_secret
JWT_ALGORITHM=HS256
# Access token TTL (recommended: 900 = 15 minutes; short-lived for security)
JWT_EXPIRES_IN=900
# Refresh token TTL (recommended: 604800 = 7 days; long-lived so users stay signed in)
REFRESH_TOKEN_EXPIRES_IN=604800

# Password rules
PASSWORD_MIN_LENGTH=12

# MongoDB (local or remote)
# Use the SAME username/password as in docker/inspectra/.env (MONGO_INITDB_ROOT_USERNAME, MONGO_INITDB_ROOT_PASSWORD).
# If you change those after the first run, Mongo keeps the old credentials; reset the volume (see README).
# Without auth (local mongo, no root user):
# MONGO_URI=mongodb://localhost:27017/inspectra
# With auth – e.g. when using Docker Mongo. Use localhost (not mongo) when running seed/API on host:
MONGO_URI=mongodb://inspectra_root:inspectra_root_password@localhost:27017/inspectra?authSource=admin
MONGO_DB_NAME=inspectra

# Seed script (optional – run: python -m mindtrace.apps.inspectra.seed)
SEED_ORG_NAME=mindtrace
SEED_SUPER_ADMIN_EMAIL=superadmin@mindtrace.ai
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_SUPER_ADMIN_FIRST_NAME=Mindtrace
SEED_SUPER_ADMIN_LAST_NAME=SuperAdmin
# Optional: set to 1/true/yes to overwrite existing super admin password with SEED_SUPER_ADMIN_PASSWORD
# SEED_FORCE_UPDATE_PASSWORD=1
